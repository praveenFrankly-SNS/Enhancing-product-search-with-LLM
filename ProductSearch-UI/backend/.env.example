# Databricks Configuration
DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-personal-access-token
VECTOR_SEARCH_ENDPOINT=your-vector-search-endpoint-name
SQL_WAREHOUSE_ID=your-sql-warehouse-id
UNITY_CATALOG_NAME=your_catalog
UNITY_SCHEMA_NAME=product_search

# Application Configuration
APP_NAME=ProductSearch Enterprise
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Security
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL_SECONDS=3600
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Search Configuration
MAX_QUERY_LENGTH=200
MAX_RESULTS_PER_PAGE=50
DEFAULT_PAGE_SIZE=20
VECTOR_SEARCH_TOP_K=100
SIMILARITY_THRESHOLD=0.5

# Performance
DATABRICKS_CONNECTION_TIMEOUT=30
DATABRICKS_READ_TIMEOUT=60
MAX_CONCURRENT_REQUESTS=10

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_REQUEST_LOGGING=True
SLOW_QUERY_THRESHOLD_MS=2000
